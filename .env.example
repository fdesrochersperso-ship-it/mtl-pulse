# Database — PostgreSQL connection string
# For Neon (recommended): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/mtl_pulse?sslmode=require
# For local Docker: postgresql://postgres:dev@localhost:5432/mtl_pulse
DATABASE_URL=postgresql://user:pass@localhost:5432/mtl_pulse

# Anthropic Claude API key for AI digest generation
ANTHROPIC_API_KEY=sk-ant-...

# Snow removal secured API token (request from donneesouvertes@montreal.ca)
SNOW_API_TOKEN=

# Secret to protect the cron trigger endpoint from unauthorized calls
CRON_SECRET=your-random-secret-here
